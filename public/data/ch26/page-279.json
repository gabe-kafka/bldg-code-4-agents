    {
      "id": "ASCE7-22-26.12.3.1-body2",
      "type": "body",
      "section": "26.12.3.1",
      "text": "For Risk Category II buildings and other structures and Risk Category III buildings and other structures, except health care facilities, the wind-borne debris region shall be based on Figure 26.5-1B. For Risk Category III health care facilities, the wind-borne debris region shall be based on Figure 26.5-1C. For Risk Category IV buildings and structures, the wind-borne debris region shall be based on Figure 26.5-1D. Risk categories shall be determined in accordance with Section 1.5.",
      "cross_references": [
        "Figure 26.5-1B",
        "Figure 26.5-1C",
        "Figure 26.5-1D",
        "Section 1.5"
