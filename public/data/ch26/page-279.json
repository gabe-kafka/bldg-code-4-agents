    {
      "id": "ASCE7-22-26.12.1-heading1",
      "type": "provision",
      "section": "26.12.1",
      "text": "26.12.1 General For the purpose of determining internal pressure coefficients, buildings and other structures for which internal pressure coefficients (GCₚᵢ) apply shall be classified as enclosed, partially enclosed, partially open, or open, as defined in Section 26.2. If a building or other structure satisfies both the \"open\" and \"partially enclosed\" enclosure classification definitions, it shall not be classified as a \"partially open\" building or other structure.",
      "cross_references": [
        "26.2"
      ],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.48,
        "y_start": 0.41,
        "y_end": 0.47
      },
      "column": "left",
